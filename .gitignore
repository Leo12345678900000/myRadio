# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# python
backend/fastapi/.venv/
__pycache__/
*.py[cod]

# local-only documentation (keep on disk, do not push)
/docs/
/FRONTEND_REWRITE_REQUIREMENTS.md
/GITHUB_PUSH_REQUIREMENTS.md
/DEV_TODO.md
/OPTIMIZATION_ROADMAP.md
/REPAIR_REPORT.md
/backend/fastapi/README.md
/scripts/release-package.ps1
